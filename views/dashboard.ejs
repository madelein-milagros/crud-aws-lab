<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>📊 Dashboard - CRUD</title>
  <style>
    body { font-family: system-ui, sans-serif; max-width: 900px; margin: 40px auto; padding: 20px; background: #f5f5f5; }
    .header { background: #fff; padding: 20px; border-radius: 8px; margin-bottom: 20px; display: flex; justify-content: space-between; align-items: center; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
    .card { background: #fff; padding: 20px; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
    table { width: 100%; border-collapse: collapse; margin-top: 15px; }
    th, td { padding: 12px; text-align: left; border-bottom: 1px solid #ddd; }
    th { background: #0066cc; color: white; }
    tr:hover { background: #f9f9f9; }
    .btn { padding: 8px 16px; border: none; border-radius: 4px; cursor: pointer; text-decoration: none; display: inline-block; margin: 2px; }
    .btn-primary { background: #0066cc; color: white; }
    .btn-success { background: #28a745; color: white; }
    .btn-warning { background: #ffc107; color: #000; }
    .btn-danger { background: #dc3545; color: white; }
    .btn:hover { opacity: 0.9; }
    .form-group { margin: 10px 0; }
    .form-group label { display: block; margin-bottom: 5px; font-weight: bold; }
    .form-group input, .form-group textarea { width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box; }
    .msg { padding: 10px; margin: 10px 0; border-radius: 4px; }
    .msg.success { background: #d4edda; color: #155724; }
    .msg.error { background: #f8d7da; color: #721c24; }
  </style>
</head>
<body>
  <div class="header">
    <h2>📋 Panel de Control - <%= user.username %></h2>
    <div>
      <a href="/logout" class="btn btn-danger">Cerrar Sesión</a>
    </div>
  </div>

  <% if (message) { %>
    <div class="card">
      <p class="msg <%= message.includes('exit') ? 'success' : 'error' %>"><%= message %></p>
    </div>
  <% } %>

  <div class="card">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
      <h3 style="margin: 0;">Lista de Items</h3>
      <a href="/items/new" class="btn btn-success">➕ Nuevo Item</a>
    </div>

    <table>
      <thead>
        <tr>
          <th>ID</th>
          <th>Nombre</th>
          <th>Descripción</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% if (items.length === 0) { %>
          <tr>
            <td colspan="4" style="text-align: center; color: #999;">No hay items registrados</td>
          </tr>
        <% } else { %>
          <% items.forEach(item => { %>
            <tr>
              <td><%= item.id %></td>
              <td><%= item.name %></td>
              <td><%= item.description %></td>
              <td>
                <a href="/items/edit/<%= item.id %>" class="btn btn-warning">✏️ Editar</a>
                <a href="/items/delete/<%= item.id %>" class="btn btn-danger" onclick="return confirm('¿Estás seguro de eliminar este item?')">🗑️ Eliminar</a>
              </td>
            </tr>
          <% }); %>
        <% } %>
      </tbody>
    </table>
  </div>
</body>
</html>