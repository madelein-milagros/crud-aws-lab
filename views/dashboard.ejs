<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>📊 Dashboard - CRUD Pro</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', system-ui, -apple-system, sans-serif;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      min-height: 100vh;
      padding: 40px 20px;
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
    }

    /* Header moderno */
    .header {
      background: rgba(255, 255, 255, 0.98);
      backdrop-filter: blur(10px);
      border-radius: 20px;
      padding: 24px 32px;
      margin-bottom: 30px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      box-shadow: 0 20px 35px -10px rgba(0, 0, 0, 0.2);
      border: 1px solid rgba(255, 255, 255, 0.3);
      transition: transform 0.3s ease;
    }

    .header:hover {
      transform: translateY(-2px);
    }

    .header h2 {
      font-size: 1.8rem;
      font-weight: 700;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .header h2 i {
      background: none;
      -webkit-text-fill-color: #667eea;
      font-size: 2rem;
    }

    /* Tarjeta principal */
    .card {
      background: white;
      border-radius: 24px;
      padding: 32px;
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
      transition: all 0.3s ease;
    }

    .card-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 28px;
      flex-wrap: wrap;
      gap: 15px;
    }

    .card-header h3 {
      font-size: 1.6rem;
      font-weight: 600;
      color: #1a202c;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    /* Botones modernos */
    .btn {
      padding: 10px 24px;
      border: none;
      border-radius: 12px;
      cursor: pointer;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-weight: 500;
      font-size: 0.9rem;
      transition: all 0.3s ease;
      font-family: 'Inter', sans-serif;
    }

    .btn-primary {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
    }

    .btn-success {
      background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
      color: white;
    }

    .btn-warning {
      background: linear-gradient(135deg, #f2994a 0%, #f2c94c 100%);
      color: white;
    }

    .btn-danger {
      background: linear-gradient(135deg, #eb3349 0%, #f45c43 100%);
      color: white;
    }

    .btn-secondary {
      background: #6c757d;
      color: white;
    }

    .btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
    }

    .btn:active {
      transform: translateY(0);
    }

    /* Tabla moderna */
    .table-container {
      overflow-x: auto;
      border-radius: 16px;
    }

    table {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0;
    }

    th {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      padding: 16px;
      font-weight: 600;
      font-size: 0.9rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    th:first-child { border-radius: 12px 0 0 0; }
    th:last-child { border-radius: 0 12px 0 0; }

    td {
      padding: 16px;
      border-bottom: 1px solid #e2e8f0;
      color: #2d3748;
    }

    tr {
      transition: all 0.2s ease;
    }

    tr:hover {
      background: #f7fafc;
      transform: scale(1.01);
    }

    /* Mensajes */
    .msg {
      padding: 16px 20px;
      margin-bottom: 20px;
      border-radius: 12px;
      font-weight: 500;
      display: flex;
      align-items: center;
      gap: 10px;
      animation: slideIn 0.3s ease;
    }

    @keyframes slideIn {
      from {
        opacity: 0;
        transform: translateY(-10px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .msg.success {
      background: #d4edda;
      color: #155724;
      border-left: 4px solid #28a745;
    }

    .msg.error {
      background: #f8d7da;
      color: #721c24;
      border-left: 4px solid #dc3545;
    }

    /* Badge vacío */
    .empty-state {
      text-align: center;
      padding: 60px 20px;
      color: #a0aec0;
    }

    .empty-state i {
      font-size: 4rem;
      margin-bottom: 15px;
      opacity: 0.5;
    }

    .empty-state p {
      font-size: 1.1rem;
    }

    /* Responsive */
    @media (max-width: 768px) {
      body {
        padding: 20px;
      }
      
      .card {
        padding: 20px;
      }
      
      .btn {
        padding: 8px 16px;
        font-size: 0.85rem;
      }
      
      th, td {
        padding: 12px;
      }
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h2>
        <i class="fas fa-chart-line"></i>
        Panel de Control - <%= user.username %>
      </h2>
      <div>
        <a href="/logout" class="btn btn-danger">
          <i class="fas fa-sign-out-alt"></i> Cerrar Sesión
        </a>
      </div>
    </div>

    <% if (message) { %>
      <div class="msg <%= message.includes('exitoso') || message.includes('exit') ? 'success' : 'error' %>">
        <i class="fas <%= message.includes('exitoso') ? 'fa-check-circle' : 'fa-exclamation-triangle' %>"></i>
        <%= message %>
      </div>
    <% } %>

    <div class="card">
      <div class="card-header">
        <h3>
          <i class="fas fa-list-ul"></i>
          Lista de Items
        </h3>
        <a href="/items/new" class="btn btn-success">
          <i class="fas fa-plus"></i> Nuevo Item
        </a>
      </div>

      <div class="table-container">
        <table>
          <thead>
            <tr>
              <th>ID</th>
              <th>Nombre</th>
              <th>Descripción</th>
              <th>Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% if (items.length === 0) { %>
              <tr>
                <td colspan="4" class="empty-state">
                  <i class="fas fa-inbox"></i>
                  <p>No hay items registrados</p>
                  <a href="/items/new" class="btn btn-success" style="margin-top: 15px;">
                    <i class="fas fa-plus"></i> Crear primer item
                  </a>
                </td>
              </tr>
            <% } else { %>
              <% items.forEach(item => { %>
                <tr>
                  <td><strong>#<%= item.id %></strong></td>
                  <td><%= item.name %></td>
                  <td><%= item.description %></td>
                  <td>
                    <a href="/items/edit/<%= item.id %>" class="btn btn-warning" style="padding: 6px 12px;">
                      <i class="fas fa-edit"></i> Editar
                    </a>
                    <a href="/items/delete/<%= item.id %>" class="btn btn-danger" style="padding: 6px 12px;" 
                       onclick="return confirm('¿Estás seguro de eliminar este item?')">
                      <i class="fas fa-trash"></i> Eliminar
                    </a>
                  </td>
                </tr>
              <% }); %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</body>
</html>